3195 A$=INPUT$(1):RETURN
3200 CLS:COLOR 23:PRINT TAB(34)"TRADUCTOR":COLOR 7:PRINT:PRINT"PROGRAMAS EXISTENTES:"
3202 FILES "*.KAR"
3205 X=2
3216 PRINT:INPUT "INDICA EL NOMBRE DEL PROGRAMA A TRADUCIR ===> ( y pulsa ENTER)";A$
3217 GOSUB 20100:IF A$="" THEN A$="TRABAJO"
3219 ' TRADUCCION DE UN PROGRAMA
3240 OPEN "I",#1,A$+".KAR":GOTO 3290
3250 PRINT"NO EXISTE UN PROGRAMA KAREL CON DICHO NOMBRE (pulsar ENTER)"
3260 A$=INPUT$(1)
3270 RETURN
3290 INPUT #1,U:FOR I=1 TO U:LINE INPUT  #1,M$(I):NEXT I:CLOSE #1
3295 NN=0:Y=0:I=1:T=1:AI=1:MAX=1
3305 CLS:LOCATE 12,32:PRINT"TRADUCIENDO"
3320 GOSUB 3999:IF D$<>"PRINCIPIO_PROGRAMA" THEN NN=NN+1:ER$(NN)=CHR$(1)+CHR$(I)
3321 GOSUB 4000
3322 IF D$="NUEVA_INSTRUCCION" THEN  3326
3323 IF D$="PRINCIPIO_EJECUCION" THEN 3329
3324 IF F=1 THEN 3327
3325 NN=NN+1:ER$(NN)=CHR$(6)+CHR$(I):GOTO 3321
3326 GOSUB 3609:IF Q=99 THEN GOSUB 4140:GOTO 3322
3327 IF F=1 THEN NN=NN+1:ER$(NN)=CHR$(3)+CHR$(I):NN=NN+1:ER$(NN)=CHR$(13)+CHR$(I):GOTO 3333
3328 GOSUB 4140:IF D$="FINAL_EJECUCION" THEN  NN=NN+1:ER$(NN)=CHR$(3)+CHR$(I):GOTO 3331 ELSE 3321
3329 T=1:B=0:GOSUB 3634:IF F=1 THEN 3333
3330 GOSUB 4140
3331 GOSUB 4000
3332 IF D$<>"FINAL_PROGRAMA" THEN NN=NN+1:ER$(NN)=CHR$(13)+CHR$(I):GOTO 3334 ELSE 3334
3333 NN=NN+1:ER$(NN)=CHR$(12)+CHR$(I):NN=NN+1:ER$(NN)=CHR$(13)+CHR$(I):GOSUB 4140
3334 GOTO 3400
3340 IF ERR<>53 THEN RESUME 3005
3341 IF X=1 THEN RESUME 3194
3342 IF X=2 THEN RESUME 3250
3400 LOCATE 12,20:PRINT NN ,"ERRORES EN LA TRADUCCION"
3405 LOCATE 23,20:PRINT"Pulsar una tecla para continuar"
3410 D$=INPUT$(1)
3420 IF NN=0 THEN  3547
3430 CLS:COLOR 23:PRINT TAB(29);"LISTADO DE ERRORES":COLOR 7
3440 LOCATE 12,5:PRINT "IMPRESORA";TAB(25);"PANTALLA";TAB(45);"VOLVER al"
3450 PRINT TAB(45);"menu anterior"
3470 LOCATE 21,20:PRINT"Indica una opcion pulsando ENTER"
3490 RJ=2:NO=3:LI=12:GOSUB 20000
3500 IF LO=3 THEN RETURN
3510 IF LO=1 THEN PRINT"CONECTAR la impresora y pulsar una tecla":RI$=INPUT$(1)
3520 CLS:FOR I=1 TO NN:X=ASC(RIGHT$(ER$(I),1))
3530 Y=ASC(LEFT$(ER$(I),1))
3540 IF LO=1 THEN ON Y GOSUB 3571,3573,3575,3577,3579,3581,3583,3585,3587,3589,3591,3593,3595,3597,3599,3601,3603 ELSE ON Y GOSUB 3570,3572,3574,3576,3578,3580,3582,3584,3586,3588,3590,3592,3594,3596,3598,3600,3602
3543 IF LO=2 THEN PRINT" en la linea ";X ELSE LPRINT" en la linea ";X
3544 NEXT I:LOCATE 24,10:PRINT"PULSA UNA TECLA PARA CONTINUAR";
3545 B$=INPUT$(1)
3546 RETURN
3547 CLS:PRINT"PROGRAMAS EJECUTABLES EXISTENTES:"
3548 PRINT "NO HAY PROGRAMAS .COD EXISTENTES"
3550 PRINT:INPUT "INDICA EL NOMBRE DEL PROGRAMA TRADUCIDO ===> ( y pulsa ENTER)";A$:GOSUB 20100:IF A$="" THEN A$="TRABAJO"
3560 CLOSE
3561 OPEN "O",#1,A$+".COD"
3562 PRINT #1,MAX
3563 FOR I=1 TO MAX:WRITE #1,CO$(I),CL$(I),NU$(I):NEXT I
3564 CLOSE #1
3565 RETURN
