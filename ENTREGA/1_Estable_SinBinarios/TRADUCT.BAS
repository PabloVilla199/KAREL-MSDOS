3603 LPRINT "Falta VECES ";:RETURN
3605 DATA FRENTE_SIN_MURO,FRENTE_CON_MURO,IZQUIERDA_SIN_MURO,IZQUIERDA_CON_MURO,DERECHA_SIN_MURO,DERECHA_CON_MURO,ESQUINA_CON_EMISORES,ESQUINA_SIN_EMISORES
3606 DATA NO_MIRANDO_AL_ESTE,MIRANDO_AL_ESTE,NO_MIRANDO_AL_OESTE,MIRANDO_AL_OESTE,NO_MIRANDO_AL_SUR,MIRANDO_AL_SUR
3607 DATA NO_MIRANDO_AL_NORTE,MIRANDO_AL_NORTE,BOLSA_CON_EMISORES,BOLSA_SIN_EMISORES
3608 ' TRADUCCION DE DEFINIR NUEVA_PALABRA
3609 GOSUB 4000:B=0:'LEE LA PALABRA SIGUIENTE
3610 GOSUB 3900:IF Q=6 THEN NN=NN+1:ER$(NN)=CHR$(4)+CHR$(I):T=P ELSE MAX=MAX+1:T=MAX:NU$(T)=D$
3615 ' PALABRA NUEVA
3620 GOSUB 4000:IF D$<>"COMO" THEN NN=NN+1:ER$(NN)=CHR$(5)+CHR$(I):I=AI:Y=AY
3630 GOSUB 4000:IF D$<>"PRINCIPIO" THEN NN=NN+1:ER$(NN)=CHR$(16)+CHR$(I)
3634 PR=1:CO$(T)=CO$(T)+CHR$(59):CL$(T)=CL$(T)+CHR$(I+50):D=0
3635 GOSUB 4000
3640 Q=0:GOSUB 3740:D=D-1:' intenta localizar la instruccion
3641 IF F=1 THEN RETURN
3642 IF Q<>55 THEN GOSUB 4280:GOTO 3635
3645 RETURN
3669 ' SI
3670 CO$(T)=CO$(T)+CHR$(56):CL$(T)=CL$(T)+CHR$(I+50):GOSUB 4000:GOSUB 4260:GOSUB 3675:GOTO 3700
3671 ' localizar la condicion
3675 RR=1:RESTORE 3605
3680 READ RR$:IF RR$=D$ THEN CO$(T)=CO$(T)+CHR$(RR+50):RETURN
3690 RR=RR+1:IF RR<19 THEN 3680
3695 NN=NN+1:ER$(NN)=CHR$(8)+CHR$(I):RETURN:' no existe esa condicion
3700 GOSUB 4000:GOSUB 4260:IF D$<>"ENTONCES" THEN NN=NN+1:ER$(NN)=CHR$(9)+CHR$(I)
3705 GOSUB 4200:Q=0:GOSUB 4000:IF D$<>"SI_NO" THEN I=AI:Y=AY:RETURN
3706 ' SI_NO
3710 D=D+1:GOSUB 4260:CO$(T)=CO$(T)+CHR$(61):CL$(T)=CL$(T)+CHR$(I+50)
3715 GOSUB 4200:Q=0
3720 D=D-1:RETURN
3740 D=D+1:Q=0:IF D$="AVANZAR" THEN CO$(T)=CO$(T)+CHR$(55):CL$(T)=CL$(T)+CHR$(I+50):RETURN
3750 IF D$="COGER_EMISOR" THEN CO$(T)=CO$(T)+CHR$(51):CL$(T)=CL$(T)+CHR$(I+50):RETURN
3760 IF D$="DEJAR_EMISOR" THEN CO$(T)=CO$(T)+CHR$(52):CL$(T)=CL$(T)+CHR$(I+50):RETURN
3770 IF D$="DESCONECTAR" THEN CO$(T)=CO$(T)+CHR$(53):CL$(T)=CL$(T)+CHR$(I+50):RETURN
3780 IF D$="IZQUIERDA" THEN CO$(T)=CO$(T)+CHR$(54):CL$(T)=CL$(T)+CHR$(I+50):RETURN
3790 IF D$="SI" THEN D=D+1:GOSUB 3670:D=D-1:RETURN
3795 IF D$="SI_NO" THEN D=D+1:GOSUB 3710:D=D-1:RETURN
3800 IF D$="MIENTRAS" THEN D=D+1:GOSUB 3850:D=D-1:RETURN
3810 IF D$="REPETIR" THEN D=D+1:GOSUB 3910:D=D-1:RETURN
3820 IF D$="FINAL" OR D$="FINAL_EJECUCION" THEN Q=55:GOSUB 4260:CO$(T)=CO$(T)+CHR$(60):CL$(T)=CL$(T)+CHR$(I+50):RETURN
3825 IF D$="NUEVA_INSTRUCCION" THEN Q=99:NIVEL=D:GOTO 4070
3826 IF D$="PRINCIPIO_EJECUCION" THEN Q=99:NIVEL=D:GOTO 4070
3830 GOSUB 3900:IF Q=6 THEN CO$(T)=CO$(T)+CHR$(P+60):CL$(T)=CL$(T)+CHR$(I+50):RETURN
3840 NN=NN+1:ER$(NN)=CHR$(6)+CHR$(I):RETURN
3849 ' MIENTRAS
3850 CO$(T)=CO$(T)+CHR$(58):CL$(T)=CL$(T)+CHR$(I+50):GOSUB 4000:GOSUB 4260:GOSUB 3675:' CONDICION
3860 GOSUB 4000:GOSUB 4260:IF D$<>"HACER" THEN NN=NN+1:ER$(NN)=CHR$(10)+CHR$(I)
3870 GOSUB 4200:Q=0
3890 RETURN
3899 ' LOCALIZAR NUEVAS INSTRUCCIONES
3900 P=2:Q=0
3902 IF P>MAX THEN RETURN
3904 IF NU$(P)=D$ THEN Q=6:RETURN
3905 P=P+1:GOTO 3902
3906 'REPETIR
3910 CO$(T)=CO$(T)+CHR$(57):CL$(T)=CL$(T)+CHR$(I+50)
3920 GOSUB 4000:GOSUB 4260:IF D$<"1" OR D$>"9" THEN NN=NN+1:ER$(NN)=CHR$(11)+CHR$(I) ELSE CO$(T)=CO$(T)+CHR$(VAL(D$)+50)
3921 GOSUB 4000:GOSUB 4260:IF D$<>"VECES" THEN NN=NN+1:ER$(NN)=CHR$(17)+CHR$(I)
3930 GOSUB 4200:Q=0
3950 RETURN
3998 ' LECTURA DE PALABRAS
3999 NO=LEN(M$(I)):R$="":T$=""
4000 D$="":D=D+1
4006 GOSUB 4066:IF F=1 THEN RETURN
4007 AY=Y:AI=I
4010 D1$=MID$(M$(I),Y,1)
4020 IF D1$<>" " THEN D$=D$+D1$:Y=Y+1:IF Y<NO+1 THEN 4010
4030 R$=T$:T$=RIGHT$(D$,1)
4035 IF T$=";" THEN D$=LEFT$(D$,LEN(D$)-1) ELSE T$=""
4040 D=D-1:GOSUB  4300:RETURN
4050 Y=0:D=D+1
4060 IF I<U THEN I=I+1:NO=LEN(M$(I)):GOTO 4066:D=D-1:RETURN:' OTRA LINEA
4064 F=1:NIVEL=D:GOTO 4070
4065 ' APUNTA A LA SIGUIENTE LINEA
4066 Y=Y+1:IF Y>NO THEN 4050
4067 D1$=MID$(M$(I),Y,1)
4068 IF D1$=" " THEN 4066
4069 D=D-1:RETURN
4070 FOR IM=1 TO NIVEL:' DEVUELVE EL CONTROL AL SUBPROGRAMA DE TRADUCCION
4080 RETURN 4090
4090 NEXT IM
4100 RETURN
4109 ' INICIO DE LAS MATRICES DE CODIGO Y NUEVAS PALABRAS
4110 FOR J=1 TO 30
4120 NU$(J)="":CO$(J)="":CL$(J)=""
4130 NEXT J:RETURN
4135 ' LOCALIZA LOS FINALES Y PRINCIPIOS AUSENTES
4140 IF B>0 THEN NN=NN+1:ER$(NN)=CHR$(7)+CHR$(I):RETURN
4150 IF B<0 THEN NN=NN+1:ER$(NN)=CHR$(16)+CHR$(I):RETURN
4160 RETURN
4199 ' TRADUCE EL CODIGO DE ESTRUCTURAS (SI,SI_NO,MIENTRAS,REPETIR)
4200 D=D+1:GOSUB 4260:CO$(T)=CO$(T)+CHR$(59):CL$(T)=CL$(T)+CHR$(I+50):GOSUB 4000:IF D$<>"PRINCIPIO" THEN 4250
4210 PR=1:B=B+1
4220 GOSUB 4000:GOSUB 3740:D=D-1
4230 IF D$<>"FINAL" THEN  GOSUB 4280:GOTO 4220
4240 B=B-1:D=D-1:PR=1:RETURN
4250 PR=1:GOSUB 3740:D=D-1:CO$(T)=CO$(T)+CHR$(60):CL$(T)=CL$(T)+CHR$(I+50):RETURN
4260 IF R$=";" THEN NN=NN+1:ER$(NN)=CHR$(14)+CHR$(I-1):RETURN
4270 RETURN
4280 IF PR=1 THEN PR=0:GOTO 4260
4285 IF R$<>";" THEN NN=NN+1:ER$(NN)=CHR$(15)+CHR$(I-1):RETURN
4290 RETURN
4299 ' TRADUCIR A MAYUSCULAS
4300 I$=D$:D$=""
4305 FOR K=1 TO LEN(I$):Y$=MID$(I$,K,1)
4306 IF Y$="-" THEN Y$="_"
4310 IF Y$>"_" THEN Y$=CHR$(ASC(Y$)-32)
4320 D$=D$+Y$:NEXT K:RETURN
20000 LO=1:CO=1:GOSUB 20200
20010 LOCATE LI,CO:READ RI$:PRINT"==> ";:COLOR 0,7:PRINT RI$;:COLOR 7,0
20020 RX$=INPUT$(1)
20021 IF RX$=CHR$(13) THEN RETURN
20025 LOCATE LI,CO:PRINT"      ";RI$;
20026 LO=LO+1:CO=CO+20:IF LO=5 THEN LI=LI+2:CO=1
20030 IF LO>NO THEN LO=1:CO=1:GOSUB 20200:IF NO>3 THEN LI=LI-2
20040 GOTO 20010
20100 IF MID$(A$,2,1)=":" THEN FI$=LEFT$(A$,2):A$=MID$(A$,3,LEN(A$))
20110 IF LEN(A$)>8 THEN A$=LEFT$(A$,8)
20120 RETURN
20130 CLS:PRINT"Indica la unidad de disco seleccionada (ej. B)":RI$=INPUT$(1)
20140 IF RI$<>"a" AND RI$<>"A" AND RI$<>"b" AND RI$<>"B" THEN 20130
20150 FI$=RI$+":":DEF SEG=&HBB00:POKE 0,ASC(FI$):DEF SEG:RETURN
20200 ON RJ GOTO 20210,20220
20205 RETURN
20210 RESTORE 20215:RETURN
20215 DATA TRADUCIR,BORRAR,CAMBIAR,VOLVER
20220 RESTORE 20225:RETURN
