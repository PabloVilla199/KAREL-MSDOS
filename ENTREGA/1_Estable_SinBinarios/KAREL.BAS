90 PRINT TAB(5);"programas";TAB(25);"mundo de Karel";TAB(45);"programas";TAB(65);"unidad de disco";
100 PRINT TAB(5);"TRADUCIR";TAB(25);"SALIR del Karel";TAB(45);"RENOMBRAR";
120 LOCATE 22,20:PRINT "Pulsar ENTER en la opcion deseada";
130 RJ=1:NO=7:LI=12:GOSUB 20000
140 IF LO=4 THEN GOTO 150
145 REM no se solicita disco en DOSBox
150 ON LO GOSUB 180,170,200,20130,190,210,400
160 GOTO 50
170 CHAIN "MANIPFIX.BAS"
180 CHAIN "EDITOR2.BAS"
190 CHAIN "TRADFIX.BAS"
200 CHAIN "EJECFIX.BAS"
210 END
300 DATA ESCRIBIR,DISENAR,EJECUTAR,CAMBIAR,TRADUCIR,SALIR,RENOMBRAR
400 CLS:PRINT TAB(20);"CAMBIAR DE NOMBRE A LOS PROGRAMAS"
410 LOCATE 10,5:PRINT"MUNDO DE KAREL";TAB(25);"PROGRAMA KAREL";TAB(45);"PROGRAMA EJECUTABLE"
420 LOCATE 22,20:PRINT"Indica una opcion pulsando ENTER"
430 LI=10:NO=3:RJ=2:GOSUB 20000
440 ON LO GOTO 450,460,470
450 B$=".MUN":GOTO 490
460 B$=".KAR":GOTO 490
470 B$=".COD":GOTO 490
490 CLS:PRINT"PROGRAMAS EXISTENTES:":FILES "*"+B$
500 PRINT:INPUT "INDICA EL NOMBRE DEL FICHERO A MODIFICAR ===> ";A$
510 GOSUB 20100:IF A$="" THEN A$="TRABAJO"
515 D$=A$
520 PRINT:INPUT "INDICA SU NUEVO NOMBRE ==> ";A$
525 GOSUB 20100:IF A$="" THEN A$="TRABAJO"
530 NAME D$+B$ AS A$+B$
540 RETURN
550 LOCATE 20,1:PRINT"NO EXISTE UN fichero de tipo ";B$;" con dicho nombre"
560 PRINT TAB(25);"Pulsa una tecla para continuar";
570 A$=INPUT$(1)
580 RETURN
600 IF ERR<>53 THEN CLS:PRINT "ERROR ";ERR;" EN LINEA ";ERL:STOP
605 RESUME 550
610 DATA "MUNDO DE KAREL","PROGRAMA KAREL","PROGRAMA EJECUTABLE"
700 ON RJ GOTO 720,730
710 RETURN
720 RESTORE 300:RETURN
730 RESTORE 610:RETURN
20000 LO=1:CO=1:GOSUB 700
20010 LOCATE LI,CO:READ RJ$:PRINT"==> ";:COLOR 0,7:PRINT RJ$;:COLOR 7,0
20020 RX$=INPUT$(1)
20021 IF RX$=CHR$(13) THEN RETURN
20025 LOCATE LI,CO:PRINT"      ";RJ$;
20026 LO=LO+1:CO=CO+20:IF LO=5 THEN LI=LI+2:CO=1
20030 IF LO>NO THEN LO=1:CO=1:GOSUB 700:IF NO>3 THEN LI=LI-2
20040 GOTO 20010
20100 IF MID$(A$,2,1)=":" THEN A$=MID$(A$,3,LEN(A$))
20110 IF LEN(A$)>8 THEN A$=LEFT$(A$,8)
20120 RETURN
20130 CLS:PRINT"En DOSBox se usa la carpeta actual"
20140 PRINT"No hace falta cambiar de unidad"
20150 PRINT"Pulsa una tecla para continuar";
20160 RI$=INPUT$(1):RETURN
